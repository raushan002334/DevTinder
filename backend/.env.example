# MongoDB Connection URI
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dbname

# Server Port
PORT=7777

# Environment mode
NODE_ENV=development

# Comma-separated allowed frontend origins
# Example: http://localhost:5173,https://your-frontend-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# JWT Secret (use a long random string in production)
JWT_SECRET=replace_with_strong_random_secret

# Admin token for protected admin routes (optional)
ADMIN_TOKEN=replace_with_admin_token

